{
  "manifest_version": 3,
  "name": "YouTube AI 번역",
  "description": "유튜브 자막을 AI로 번역해 스크립트 패널과 영상 오버레이로 표시.",
  "version": "0.1.1",
  "minimum_chrome_version": "111",
  "permissions": ["storage", "webRequest"],
  "host_permissions": ["*://*.youtube.com/*", "http://localhost/*"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube AI 번역",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": [
        "constants.js",
        "content/core.js",
        "content/panel.js",
        "content/overlay.js",
        "content/main.js"
      ],
      "css": ["panel.css", "overlay.css"],
      "run_at": "document_start"
    }
  ]
}
